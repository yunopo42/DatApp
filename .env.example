# Application
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# PostgreSQL development container
POSTGRES_DB=datapp
POSTGRES_USER=datapp
POSTGRES_PASSWORD=change-me-for-local-development
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Backend database connection
DATABASE_URL=postgresql+psycopg://datapp:change-me-for-local-development@localhost:5432/datapp

# Managed OIDC authentication (configure before exposing protected APIs)
AUTH_ISSUER=https://your-auth-provider.example.com/
AUTH_AUDIENCE=datapp-api
AUTH_JWKS_URL=https://your-auth-provider.example.com/.well-known/jwks.json
AUTH_ALGORITHM=RS256

# Frontend
VITE_API_BASE_URL=http://localhost:8000
