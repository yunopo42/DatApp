# Application
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# PostgreSQL development container
POSTGRES_DB=datapp
POSTGRES_USER=datapp
POSTGRES_PASSWORD=change-me-for-local-development
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Backend database connection
DATABASE_URL=postgresql+psycopg://datapp:change-me-for-local-development@localhost:5432/datapp

# Supabase Auth with asymmetric JWT signing keys
AUTH_ISSUER=https://your-project-ref.supabase.co/auth/v1
AUTH_AUDIENCE=authenticated
AUTH_JWKS_URL=https://your-project-ref.supabase.co/auth/v1/.well-known/jwks.json
AUTH_ALGORITHM=ES256

# Upload policy (25 MiB by default)
UPLOAD_MAX_BYTES=26214400

# Frontend
VITE_API_BASE_URL=http://localhost:8000
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_replace_me
